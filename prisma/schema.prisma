generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// --- 1. ENUMOK ---
enum ForrasTipus {
  RSS
  TWITTER
  REDDIT
  YOUTUBE
  API
}

enum ErtesitesTipus {
  EMAIL
  DISCORD
  TELEGRAM
}

// --- 2. FELHASZNÁLÓK TÁBLA ---
model Felhasznalok {
  id                  Int       @id @default(autoincrement())
  username            String    @unique
  email               String    @unique
  password_hash       String?
  role                String?   @default("user")
  subscription_tier   String?   @default("alap")
  ai_provider         String?
  api_key             String?
  custom_ai_endpoint  String?
  regisztracio_datuma DateTime? @default(now())

  // Értesítési adatok a riasztásokhoz
  discord_webhook     String?
  telegram_chat_id    String?
  preferalt_csatorna  ErtesitesTipus @default(EMAIL)

  // Kapcsolatok
  hir_forrasok    HirForrasok[] 
  hirek           Hirek[]
  ertesitesek     Ertesitesek[]
  rendszer_naplok RendszerNaplo[]
  kulcsszavak     FelhasznaloKulcsszavak[]
}

// --- 3. HÍRFORRÁSOK ---
model HirForrasok {
  id               Int       @id @default(autoincrement())
  felhasznalo_id   Int?      // Ha üres, globális forrás
  forras_url       String
  forras_nev       String?
  tipus            ForrasTipus @default(RSS)
  kategoria        String?
  is_global        Boolean?  @default(false)
  aktiv            Boolean   @default(true)
  utolso_frissites DateTime?

  felhasznalo Felhasznalok? @relation(fields: [felhasznalo_id], references: [id], onDelete: Cascade)
  hirek       Hirek[]
}

// --- 4. HÍREK TÁBLA  ---
model Hirek {
  id             Int       @id @default(autoincrement())
  cim            String
  url            String?   @unique 
  tartalom       String?   @db.Text
  datum          DateTime? @default(now())
  felhasznalo_id Int?
  forras_id      Int?      
  is_private     Boolean?  @default(false)
  jelentoz       Boolean   @default(false) 

  felhasznalo Felhasznalok? @relation(fields: [felhasznalo_id], references: [id], onDelete: SetNull)
  forras      HirForrasok?  @relation(fields: [forras_id], references: [id])

  ai_elemzesek AiElemzesek[]
  ertesitesek  Ertesitesek[]
}

// --- 5. AI ELEMZÉSEK ---
model AiElemzesek {
  id               Int       @id @default(autoincrement())
  hir_id           Int
  hangulat         String?
  osszefoglalo     String?
  kulcsszavak      String[]
  hasznalt_modell  String?
  elemzes_datuma   DateTime? @default(now())

  hir Hirek @relation(fields: [hir_id], references: [id], onDelete: Cascade)
}

// --- 6. ÉRTESÍTÉSEK NAPLÓJA ---
model Ertesitesek {
  id             Int             @id @default(autoincrement())
  felhasznalo_id Int
  hir_id         Int?
  csatorna       ErtesitesTipus? 
  uzenet         String?         @db.Text
  sikeres        Boolean         @default(true)
  elkuldve_ekkor DateTime?       @default(now())

  felhasznalo Felhasznalok @relation(fields: [felhasznalo_id], references: [id], onDelete: Cascade)
  hir         Hirek?       @relation(fields: [hir_id], references: [id])
}

// --- 7. RENDSZERNAPLÓ ---
model RendszerNaplo {
  id             Int      @id @default(autoincrement())
  felhasznalo_id Int?
  esemeny_tipus  String 
  leiras         String
  ip_cim         String?
  letrehozva     DateTime @default(now())

  felhasznalo Felhasznalok? @relation(fields: [felhasznalo_id], references: [id], onDelete: SetNull)
}

// --- 8. FELHASZNÁLÓI KULCSSZAVAK ---
model FelhasznaloKulcsszavak {
  id             Int          @id @default(autoincrement())
  kulcsszo       String       
  felhasznalo_id Int
  hozzadas_ideje DateTime     @default(now())

  felhasznalo    Felhasznalok @relation(fields: [felhasznalo_id], references: [id], onDelete: Cascade)

  // Biztosítja, hogy egy user ne vehesse fel kétszer ugyanazt a szót
  @@unique([felhasznalo_id, kulcsszo]) 
}